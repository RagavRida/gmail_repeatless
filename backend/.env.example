# ============================================================
# Gmail Repeatless — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.
# ============================================================

# === Server ===
PORT=3001                                    # Express server port
NODE_ENV=development                         # development | production

# === Supabase (PostgreSQL + pgvector) ===
SUPABASE_URL=https://your-project.supabase.co       # Supabase project URL (Settings → API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # Service role key (NOT anon key) — has full DB access

# === Google OAuth2 (Gmail API access) ===
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com   # OAuth2 Client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret                      # OAuth2 Client Secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback  # Must match the authorized redirect URI in Cloud Console

# === Gemini AI (Primary model for reasoning + embeddings) ===
GEMINI_API_KEY=AIzaSy-your-gemini-key                # API key from https://aistudio.google.com/apikey
GEMINI_CHAT_MODEL=gemini-2.5-flash                   # Model for summarization, RAG synthesis, compose
GEMINI_EMBEDDING_MODEL=gemini-embedding-001           # Model for vector embeddings (768 dimensions)

# === NVIDIA NIM (Secondary model for classification) ===
NVIDIA_NIM_API_KEY=nvapi-your-nim-key                # API key from https://build.nvidia.com
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1  # NIM API endpoint (OpenAI-compatible)
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct         # Model for email categorization (6-class classification)

# === Security ===
# Generate these with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=generate-a-64-char-hex-string   # 32-byte hex key for AES-256-GCM token encryption
SESSION_SECRET=generate-a-64-char-hex-string         # Secret for express-session cookie signing

# === Frontend ===
FRONTEND_URL=http://localhost:3000                   # Frontend dev server URL (Vite default)
